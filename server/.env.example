# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to SQLite file (auto-created on first run)
SQLITE_PATH=./database.sqlite

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── MyScheme Crawler ─────────────────────────────────────────────────────────
# Base URL for the MyScheme.gov.in API
MYSCHEME_API_BASE=https://api.myscheme.gov.in/schemes/v6/public/schemes

# API key extracted from MyScheme.gov.in frontend source
MYSCHEME_API_KEY=tYTy5eEhlu9rFjyxuCr7ra7ACp4dv1RH8gWuHTDc

# ─── Crawler Tuning ───────────────────────────────────────────────────────────
# How many schemes to process per batch
CRAWLER_BATCH_SIZE=50

# Delay (ms) between each scheme fetch — be respectful to the API
CRAWLER_DELAY_MS=2000

# Cron schedule for automatic crawling (default: every 12 hours)
CRAWLER_CRON_SCHEDULE=0 */12 * * *

# Request timeout (ms)
CRAWLER_TIMEOUT=30000

# Max retries per request
CRAWLER_MAX_RETRIES=3

# Optional: comma-separated proxy list
# CRAWLER_PROXIES=http://user:pass@host:port,http://host2:port2
